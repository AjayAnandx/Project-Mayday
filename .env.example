# Mayday — Environment Variables
# Copy this file to .env and fill in your keys before starting the service.
# .env is already in .gitignore — it will not be committed.

# Deepgram API key — required for voice TTS
# Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# GitHub Personal Access Token — required for github-mcp-server tools
# Create at https://github.com/settings/tokens (needs repo + contents scopes)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Exa AI Search API key — required for web search tools
# Get at https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Optional — override the Ollama endpoint
# OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions

# Optional — override the projects directory
# PROJECTS_DIR=
